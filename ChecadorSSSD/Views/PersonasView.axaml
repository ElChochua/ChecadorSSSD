<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ChecadorSSSD.Views.PersonasView"
             x:DataType="vm:PersonasViewModel"
             xmlns:vm="clr-namespace:ChecadorSSSD.ViewModels"
             xmlns:models="clr-namespace:ChecadorSSSD.Models"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <Grid Margin="24">
        <Grid RowDefinitions="Auto,*">
            <Grid Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Personas" FontSize="24" FontWeight="Bold" Foreground="{StaticResource BrushDoradoUniversidad}"/>
                    <TextBlock Text="Busqueda de usuarios registrados en el sistema" FontSize="12" Foreground="{StaticResource BrushGrisTextoClaro}"/>
                </StackPanel>
                <TextBox Grid.Column="1"
                         Text="{Binding Busqueda}"
                         PlaceholderText="Buscar..."
                         Width="300"
                         Height="36"
                         VerticalContentAlignment="Center"
                         Background="{StaticResource BrushAzulMarinoClaro}"
                         Foreground="{StaticResource BrushBlanco}"
                         CaretBrush="{StaticResource BrushBlanco}"
                         CornerRadius="6"
                         Padding="10,0"
                         FontSize="13"/>
            </Grid>

            <!-- Tabla de personas -->
            <Border Grid.Row="1" Background="{StaticResource BrushAzulMarinoSidebar}" CornerRadius="12" Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <!-- Headers -->
                    <Border Grid.Row="0" Background="{StaticResource BrushAzulMarinoMedio}" CornerRadius="8,8,0,0" Padding="12,10">
                        <Grid ColumnDefinitions="*,*,*,Auto">
                            <TextBlock Grid.Column="0" Text="Nombre completo" FontWeight="SemiBold" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Numero de cuenta" FontWeight="SemiBold" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Rol" FontWeight="SemiBold" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Acciones" FontWeight="SemiBold" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ListBox ItemsSource="{Binding Personas}" Background="Transparent" BorderThickness="0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:Personas">
                                    <Border Background="Transparent" Padding="12,10" Margin="0" BorderBrush="{StaticResource BrushAzulMarinoClaro}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,*,*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding NombreCompleto}" Foreground="{StaticResource BrushBlanco}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Matricula}" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <Border Grid.Column="2" Background="{StaticResource BrushDoradoUniversidad}" CornerRadius="4" Padding="8,2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding TipoPersona}" Foreground="{StaticResource BrushNegro}" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <Button Content="Ver"
                                                        Command="{Binding $parent[ItemsControl].DataContext.VerCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="{StaticResource BrushAzulMarinoMedio}"
                                                        Foreground="{StaticResource BrushBlanco}"
                                                        Height="28" FontSize="10"
                                                        Padding="8,0"
                                                        FontWeight="SemiBold"
                                                        CornerRadius="4"
                                                        ToolTip.Tip="Ver detalle"/>
                                                <Button Content="Copiar"
                                                        Command="{Binding $parent[ItemsControl].DataContext.CopiarMatriculaCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="{StaticResource BrushDoradoUniversidad}"
                                                        Foreground="{StaticResource BrushNegro}"
                                                        Height="28" FontSize="10"
                                                        Padding="8,0"
                                                        FontWeight="SemiBold"
                                                        CornerRadius="4"
                                                        ToolTip.Tip="Copiar matricula"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
