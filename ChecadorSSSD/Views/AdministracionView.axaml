<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ChecadorSSSD.Views.AdministracionView"
             x:DataType="vm:AdministracionViewModel"
              xmlns:vm="clr-namespace:ChecadorSSSD.ViewModels"
              xmlns:models="clr-namespace:ChecadorSSSD.Models"
              xmlns:services="clr-namespace:ChecadorSSSD.Services"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <Grid Background="{StaticResource BrushAzulMarino}" RowDefinitions="Auto,*">
        <!-- Login Panel -->
        <Border Grid.Row="0"
                IsVisible="{Binding !Autenticado}"
                Background="{StaticResource BrushAzulFondoCont}"
                BorderBrush="{StaticResource BrushCappuccino}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="48,32"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="400"
                Margin="0,40,0,0">
            <StackPanel Spacing="24" HorizontalAlignment="Stretch">
                <!-- Logo/Icono -->
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <Image Source="avares://ChecadorSSSD/Assets/Icons/lock.png" Width="48" Height="48"/>
                    <TextBlock Text="Administracion" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BrushDoradoUniversidad}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Acceso restringido a personal autorizado" FontSize="14" Foreground="{StaticResource BrushGrisTextoClaro}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Campos de login -->
                <StackPanel Spacing="16" HorizontalAlignment="Stretch">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Usuario" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Medium"/>
                        <TextBox Text="{Binding UsuarioLogin}" PlaceholderText="Ingrese su usuario" FontSize="14" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CaretBrush="{StaticResource BrushBlanco}" Height="42" CornerRadius="2" Padding="14,0,14,0" VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Contrasena" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Medium"/>
                        <TextBox Text="{Binding PassLogin}" PasswordChar="*" PlaceholderText="Ingrese su contrasena" FontSize="14" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CaretBrush="{StaticResource BrushBlanco}" Height="42" CornerRadius="2" Padding="14,0,14,0" VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </StackPanel>

                <!-- Mensaje de error -->
                <Border Background="{StaticResource BrushRojoError}" CornerRadius="2" Padding="12,8" IsVisible="{Binding MostrarMensajeLogin}" HorizontalAlignment="Stretch">
                    <TextBlock Text="{Binding MensajeLogin}" FontSize="12" Foreground="{StaticResource BrushBlanco}" TextWrapping="Wrap"/>
                </Border>

                <!-- Boton login -->
                <Button Command="{Binding LoginCommand}" IsDefault="True" Height="48" FontSize="16" FontWeight="Bold" CornerRadius="2" HorizontalAlignment="Stretch" Background="{StaticResource BrushDoradoUniversidad}" Foreground="{StaticResource BrushNegro}">
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Text="Iniciar Sesion" VerticalAlignment="Center"/>
                        <Image Source="avares://ChecadorSSSD/Assets/Icons/forward.png" Width="20" Height="20" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Admin Panel -->
        <Grid Grid.Row="1" IsVisible="{Binding Autenticado}"
              RowDefinitions="Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <TextBlock Grid.Column="0" Text="Bienvenid@" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BrushDoradoUniversidad}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Command="{Binding LogoutCommand}" Content="Cerrar Sesion" Height="36" Padding="14,0" Background="{StaticResource BrushRojoError}" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </Grid>
            <TabControl Grid.Row="1" Background="Transparent">
                <TabItem Header="Personas" Foreground="{StaticResource BrushBlanco}">
                    <Grid ColumnDefinitions="*,400">
                        <Grid Grid.Column="0" RowDefinitions="Auto,*">
                            <Grid Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                                <TextBox Grid.Column="0" Text="{Binding BusquedaAdmin}" PlaceholderText="Buscar persona..." Height="36" Background="{StaticResource BrushAzulFondoCont}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" Padding="10,0" VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Command="{Binding NuevoPersonaCommand}" Content="+ Nuevo" Background="{StaticResource BrushVerdeExito}" Foreground="{StaticResource BrushBlanco}" Height="36" Padding="12,0" Margin="8,0,0,0" CornerRadius="2" FontWeight="SemiBold"/>
                            </Grid>
                            <Border Grid.Row="1" Background="{StaticResource BrushAzulFondoCont}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="4" Padding="0">
                                <Grid RowDefinitions="Auto,*">
                                    <!-- Headers -->
                                    <Border Grid.Row="0" Background="{StaticResource BrushAzulMarinoMedio}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="0,0,0,1" Padding="12,10">
                                        <Grid ColumnDefinitions="*,*,*,Auto">
                                            <TextBlock Grid.Column="0" Text="Nombre completo" FontWeight="SemiBold" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Matricula" FontWeight="SemiBold" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="Rol" FontWeight="SemiBold" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="Acciones" FontWeight="SemiBold" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ListBox ItemsSource="{Binding Personas}" Background="Transparent" BorderThickness="0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="models:Personas">
                                                    <Border Background="Transparent" Padding="12,10" Margin="0">
                                                        <Grid ColumnDefinitions="*,*,*,Auto">
                                                            <TextBlock Grid.Column="0" Text="{Binding NombreCompleto}" Foreground="{StaticResource BrushBlanco}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Matricula}" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                            <Border Grid.Column="2" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="2" Padding="8,2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding TipoPersona}" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="11" FontWeight="SemiBold"/>
                                                            </Border>
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                                <Button Command="{Binding $parent[ItemsControl].DataContext.EditarCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="{StaticResource BrushAzulMarinoMedio}"
                                                                        Foreground="{StaticResource BrushBlanco}"
                                                                        Height="28" Width="28"
                                                                        CornerRadius="2"
                                                                        ToolTip.Tip="Editar">
                                                                    <Image Source="avares://ChecadorSSSD/Assets/Icons/edit.png" Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                </Button>
                                                                <Button Command="{Binding $parent[ItemsControl].DataContext.EliminarCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="{StaticResource BrushRojoError}"
                                                                        Foreground="{StaticResource BrushBlanco}"
                                                                        Height="28" Width="28"
                                                                        CornerRadius="2"
                                                                        ToolTip.Tip="Eliminar">
                                                                    <Image Source="avares://ChecadorSSSD/Assets/Icons/delete.png" Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ListBox>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                        <!-- Formulario de edicion -->
                        <Grid Grid.Column="1" Margin="16,0,0,0">
                            <Border Background="{StaticResource BrushAzulFondoCont}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="4" Padding="20">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="{Binding TituloFormulario}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushBlanco}" Margin="0,0,0,8"/>
                                    <StackPanel Spacing="4"><TextBlock Text="Nombre" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Medium"/><TextBox Text="{Binding PersonaEnEdicion.Nombre}" PlaceholderText="Nombre" Height="36" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" Padding="10,0" VerticalContentAlignment="Center"/></StackPanel>
                                    <StackPanel Spacing="4"><TextBlock Text="Apellido Paterno" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Medium"/><TextBox Text="{Binding PersonaEnEdicion.ApellidoPaterno}" PlaceholderText="Apellido Paterno" Height="36" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" Padding="10,0" VerticalContentAlignment="Center"/></StackPanel>
                                    <StackPanel Spacing="4"><TextBlock Text="Apellido Materno" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Medium"/><TextBox Text="{Binding PersonaEnEdicion.ApellidoMaterno}" PlaceholderText="Apellido Materno" Height="36" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" Padding="10,0" VerticalContentAlignment="Center"/></StackPanel>
                                    <StackPanel Spacing="4"><TextBlock Text="Matricula" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Medium"/><TextBox Text="{Binding PersonaEnEdicion.Matricula}" PlaceholderText="Matricula" Height="36" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" Padding="10,0" VerticalContentAlignment="Center"/></StackPanel>
                                    <StackPanel Spacing="4"><TextBlock Text="Tipo" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Medium"/><ComboBox ItemsSource="{Binding TiposUsuario}" SelectedItem="{Binding PersonaEnEdicion.TipoPersona}" Height="36" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" Padding="10,0" VerticalContentAlignment="Center"/></StackPanel>
                                    
                                    <!-- Captura de huella -->
                                    <StackPanel Spacing="4" Margin="0,8,0,0">
                                        <TextBlock Text="Huella Dactilar" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Medium"/>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding EstadoHuellaText}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="1" Command="{Binding CapturarHuellaCommand}" Content="Capturar" Height="28" Padding="12,0" Background="{StaticResource BrushVerdeExito}" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
                                        <Button Command="{Binding GuardarCommand}" Content="Guardar" Height="40" Padding="24,0" Background="{StaticResource BrushDoradoUniversidad}" Foreground="{StaticResource BrushNegro}" CornerRadius="2" FontWeight="SemiBold" HorizontalAlignment="Stretch"/>
                                        <Button Command="{Binding CancelarCommand}" Content="Cancelar" Height="40" Padding="24,0" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" FontWeight="SemiBold" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem Header="Reportes" Foreground="{StaticResource BrushBlanco}">
                    <Grid RowDefinitions="Auto,Auto,Auto,*">
                        <Grid Grid.Row="0" ColumnDefinitions="*,*" Margin="0,0,0,12">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="Personas disponibles" FontSize="14" FontWeight="Bold" Foreground="{StaticResource BrushDoradoUniversidad}"/>
                                <TextBox Text="{Binding BusquedaPersonasReporte, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Buscar personas..." Width="300" HorizontalAlignment="Left" Height="36" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" Padding="10,0" VerticalContentAlignment="Center"/>
                                <Border Background="{StaticResource BrushAzulFondoCont}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="2" Padding="8" MaxHeight="200">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding PersonasFiltradasReporte}" Background="Transparent">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="models:Personas">
                                                    <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                        <TextBlock Grid.Column="0" Text="{Binding NombreCompleto}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="1" Content="+" Command="{Binding $parent[ItemsControl].DataContext.AgregarPersonaReporteCommand}" CommandParameter="{Binding}" Background="{StaticResource BrushVerdeExito}" Foreground="{StaticResource BrushBlanco}" Height="24" Width="24" CornerRadius="2" FontSize="10" FontWeight="Bold"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="8" Margin="8,0,0,0">
                                <TextBlock Text="Personas Seleccionadas" FontSize="14" FontWeight="Bold" Foreground="{StaticResource BrushDoradoUniversidad}"/>
                                <Border Background="{StaticResource BrushAzulFondoCont}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="2" Padding="8" MaxHeight="200">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding PersonasSeleccionadasReporte}" Background="Transparent">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="models:Personas">
                                                    <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                        <TextBlock Grid.Column="0" Text="{Binding NombreCompleto}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="1" Content="-" Command="{Binding $parent[ItemsControl].DataContext.QuitarPersonaReporteCommand}" CommandParameter="{Binding}" Background="{StaticResource BrushRojoError}" Foreground="{StaticResource BrushBlanco}" Height="24" Width="24" CornerRadius="2" FontSize="10" FontWeight="Bold"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                            <ComboBox ItemsSource="{Binding TiposReporte}" SelectedItem="{Binding TipoReporteSeleccionado}" PlaceholderText="Tipo de reporte..." Width="200" Height="36" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" Padding="10,0" VerticalContentAlignment="Center"/>
                            <DatePicker SelectedDate="{Binding FechaInicioReporte}" Height="36" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2"/>
                            <DatePicker SelectedDate="{Binding FechaFinReporte}" Height="36" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2"/>
                            <Button Command="{Binding GenerarReporteIndividuaCommand}" Content="Generar Reporte" Height="36" Padding="12,0" Background="{StaticResource BrushDoradoUniversidad}" Foreground="{StaticResource BrushNegro}" CornerRadius="2" FontWeight="SemiBold"/>
                        </StackPanel>
                        <!-- Busqueda + Paginador -->
                        <Border Grid.Row="2" Background="{StaticResource BrushAzulFondoCont}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="2" Padding="8,4" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                <TextBox Text="{Binding BusquedaReporte}" PlaceholderText="Buscar..." Width="200" Height="32" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" Padding="8,0" VerticalContentAlignment="Center" FontSize="12"/>
                                <Button Content="Anterior" Command="{Binding PaginaAnteriorCommand}" Padding="8,2" Background="Transparent" Foreground="{StaticResource BrushGrisTextoClaro}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="0" FontSize="12"/>
                                <TextBlock Text="{Binding RangoPaginaText}" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" VerticalAlignment="Center" Padding="8,0"/>
                                <Button Content="Siguiente" Command="{Binding PaginaSiguienteCommand}" Padding="8,2" Background="Transparent" Foreground="{StaticResource BrushGrisTextoClaro}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="0" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <!-- Resultados HORAS -->
                        <Grid Grid.Row="3" IsVisible="{Binding MostrarResultadosHoras}">
                            <Grid RowDefinitions="Auto,*">
                                <Border Grid.Row="0" Background="{StaticResource BrushAzulMarinoMedio}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="0,0,0,1" Padding="12,8">
                                    <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                                        <Button Grid.Column="0" Content="Nombre Completo" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                                        <Button Grid.Column="1" Content="Matricula" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                                        <Button Grid.Column="2" Content="Rol" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                                        <Button Grid.Column="3" Content="Asistencias" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                                        <Button Grid.Column="4" Content="Entradas" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                                        <Button Grid.Column="5" Content="Salidas" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                                        <Button Grid.Column="6" Content="Horas" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                                    </Grid>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ResultadosPaginadosHoras}" Background="Transparent">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="services:ReporteItem">
                                                <Border Background="{StaticResource BrushAzulMarinoMedio}" Padding="12,8" BorderBrush="{StaticResource BrushAzulMarinoClaro}" BorderThickness="0,0,0,1">
                                                    <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                                                        <TextBlock Grid.Column="0" Text="{Binding NombreCompleto}" Foreground="{StaticResource BrushBlanco}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Matricula}" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                        <Border Grid.Column="2" Background="{StaticResource BrushAzulMarino}" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="2">
                                                            <TextBlock Text="{Binding Rol}" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="10" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="3" Text="{Binding TotalAsistencias}" Foreground="{StaticResource BrushVerdeExito}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding TotalEntradas}" Foreground="{StaticResource BrushRojoError}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="5" Text="{Binding TotalSalidas}" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding HorasAcumuladas}" Foreground="{StaticResource BrushBlanco}" FontSize="12" FontWeight="SemiBold"/>
                                                            <TextBlock Text=" hrs" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                        <!-- Resultados USUARIOS -->
                        <Grid Grid.Row="3" IsVisible="{Binding MostrarResultadosUsuarios}">
                            <Grid RowDefinitions="Auto,*">
                                <Border Grid.Row="0" Background="{StaticResource BrushAzulMarinoMedio}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="0,0,0,1" Padding="12,8">
                                    <Grid ColumnDefinitions="*,*,*,*,*,*,*,*,*,*">
                                        <TextBlock Grid.Column="0" Text="Matricula" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Nombre" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Apellido P" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="Apellido M" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="Fecha" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="Entrada" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="6" Text="Salida" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="7" Text="Horas Dia" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="8" Text="Clasificacion" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="9" Text="Horas Trab" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ResultadosPaginadosUsuarios}" Background="Transparent">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="services:ReporteDetalleItem">
                                                <Border Background="{StaticResource BrushAzulMarinoMedio}" Padding="12,8" BorderBrush="{StaticResource BrushAzulMarinoClaro}" BorderThickness="0,0,0,1">
                                                    <Grid ColumnDefinitions="*,*,*,*,*,*,*,*,*,*">
                                                        <TextBlock Grid.Column="0" Text="{Binding Matricula}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="100"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Nombre}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="100"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ApellidoPaterno}" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="100"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding ApellidoMaterno}" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="100"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding Fecha, StringFormat={}{0:yyyy-MM-dd}}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="5" Text="{Binding HoraEntrada}" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                                        <TextBlock Grid.Column="6" Text="{Binding HoraSalida}" Foreground="{StaticResource BrushRojoError}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                                        <TextBlock Grid.Column="7" Text="{Binding HorasDiarias}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                        <Border Grid.Column="8" Background="{StaticResource BrushDoradoUniversidad}" CornerRadius="2" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ClasificacionHoras}" Foreground="{StaticResource BrushNegro}" FontSize="10" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="9" Text="{Binding HorasTrabajadas}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem Header="Imagenes" Foreground="{StaticResource BrushBlanco}">
                    <Grid ColumnDefinitions="400,*" Margin="0,0,0,0" HorizontalAlignment="Stretch">
                        <!-- Contenedor Izquierda: Logos Institucionales -->
                        <Border Grid.Column="0"
                                Background="{StaticResource BrushAzulFondoCont}"
                                BorderBrush="{StaticResource BrushCappuccino}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="20"
                                Margin="0,0,12,0"
                                VerticalAlignment="Stretch">
                            <Grid RowDefinitions="Auto,Auto,Auto,*">
                                <TextBlock Grid.Row="0" Text="Logos Institucionales" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushDoradoUniversidad}" Margin="0,0,0,16"/>

                                <!-- Logo Universidad -->
                                <Border Grid.Row="1" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,12">
                                    <Grid RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Text="Logo Universidad" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource BrushBlanco}" Margin="0,0,0,8"/>
                                        <Border Grid.Row="1" Background="{StaticResource BrushAzulFondoCont}" CornerRadius="2" Height="120" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                            <Image Source="{Binding VistaPreviaLogoUniversidad}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding HasVistaPreviaLogoUniversidad}"/>
                                        </Border>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                            <Button Height="36" Width="36" Padding="0" Background="{StaticResource BrushDoradoUniversidad}" Foreground="{StaticResource BrushNegro}" CornerRadius="2" FontWeight="SemiBold" Click="SeleccionarUniversidad_Click" ToolTip.Tip="Seleccionar imagen">
                                                <Image Source="avares://ChecadorSSSD/Assets/Icons/image_up.png" Width="18" Height="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Button>
                                            <Button Height="36" Width="36" Padding="0" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" FontWeight="SemiBold" Click="ActualizarUniversidad_Click" ToolTip.Tip="Actualizar">
                                                <Image Source="avares://ChecadorSSSD/Assets/Icons/forward.png" Width="18" Height="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Logo Modulo -->
                                <Border Grid.Row="2" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,12">
                                    <Grid RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Text="Logo Modulo" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource BrushBlanco}" Margin="0,0,0,8"/>
                                        <Border Grid.Row="1" Background="{StaticResource BrushAzulFondoCont}" CornerRadius="2" Height="120" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                            <Image Source="{Binding VistaPreviaLogo}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding HasVistaPreviaLogo}"/>
                                        </Border>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                            <Button Height="36" Width="36" Padding="0" Background="{StaticResource BrushDoradoUniversidad}" Foreground="{StaticResource BrushNegro}" CornerRadius="2" FontWeight="SemiBold" Click="SeleccionarLogo_Click" ToolTip.Tip="Seleccionar imagen">
                                                <Image Source="avares://ChecadorSSSD/Assets/Icons/image_up.png" Width="18" Height="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Button>
                                            <Button Height="36" Width="36" Padding="0" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" FontWeight="SemiBold" Click="ActualizarLogo_Click" ToolTip.Tip="Actualizar">
                                                <Image Source="avares://ChecadorSSSD/Assets/Icons/forward.png" Width="18" Height="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Logo Lugar -->
                                <Border Grid.Row="3" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="4" Padding="16">
                                    <Grid RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Text="Logo Lugar" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource BrushBlanco}" Margin="0,0,0,8"/>
                                        <Border Grid.Row="1" Background="{StaticResource BrushAzulFondoCont}" CornerRadius="2" Height="120" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                            <Image Source="{Binding VistaPreviaLugar}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding HasVistaPreviaLugar}"/>
                                        </Border>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                            <Button Height="36" Width="36" Padding="0" Background="{StaticResource BrushDoradoUniversidad}" Foreground="{StaticResource BrushNegro}" CornerRadius="2" FontWeight="SemiBold" Click="SeleccionarLugar_Click" ToolTip.Tip="Seleccionar imagen">
                                                <Image Source="avares://ChecadorSSSD/Assets/Icons/image_up.png" Width="18" Height="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Button>
                                            <Button Height="36" Width="36" Padding="0" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" FontWeight="SemiBold" Click="ActualizarLugar_Click" ToolTip.Tip="Actualizar">
                                                <Image Source="avares://ChecadorSSSD/Assets/Icons/forward.png" Width="18" Height="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Contenedor Derecha: Carrusel Sidebar -->
                        <Border Grid.Column="1"
                                Background="{StaticResource BrushAzulFondoCont}"
                                BorderBrush="{StaticResource BrushCappuccino}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="20"
                                VerticalAlignment="Stretch">
                            <Grid RowDefinitions="Auto,*">
                                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="0,0,0,12">
                                    <TextBlock Text="Carrusel Sidebar" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushDoradoUniversidad}" VerticalAlignment="Center"/>
                                    <Button Height="36" Width="36" Background="{StaticResource BrushVerdeExito}" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" FontWeight="SemiBold" FontSize="20" Padding="0" Margin="8,0,0,0" Click="SeleccionarImagenCarrusel_Click" ToolTip.Tip="Agregar imagen">
                                        <Image Source="avares://ChecadorSSSD/Assets/Icons/image_up.png" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ImagenesCarrusel}" Background="Transparent">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="services:ImagenCarrusel">
                                                <Border Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="4" Width="200" Height="130">
                                                    <Grid RowDefinitions="*,Auto">
                                                        <Border Grid.Row="0" Background="{StaticResource BrushAzulFondoCont}" CornerRadius="2" Margin="0,0,0,4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                            <Image Source="{Binding RutaPreview}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Row="1" Text="{Binding Nombre}" Foreground="{StaticResource BrushBlanco}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="Administradores" Foreground="{StaticResource BrushBlanco}">
                    <Grid ColumnDefinitions="*,400">
                        <Grid Grid.Column="0" RowDefinitions="Auto,*">
                            <Grid Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                                <TextBlock Grid.Column="0" Text="Administradores registrados" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushDoradoUniversidad}" Margin="0,0,0,8"/>
                                <Button Grid.Column="1" Command="{Binding NuevoAdminCommand}" Content="+ Nuevo" Background="{StaticResource BrushVerdeExito}" Foreground="{StaticResource BrushBlanco}" Height="36" Padding="12,0" Margin="8,0,0,0" CornerRadius="2" FontWeight="SemiBold"/>
                            </Grid>
                            <Border Grid.Row="1" Background="{StaticResource BrushAzulFondoCont}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="4" Padding="0">
                                <Grid RowDefinitions="Auto,*">
                                    <!-- Headers -->
                                    <Border Grid.Row="0" Background="{StaticResource BrushAzulMarinoMedio}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="0,0,0,1" Padding="12,10">
                                        <Grid ColumnDefinitions="*,*,*,Auto">
                                            <TextBlock Grid.Column="0" Text="Usuario" FontWeight="SemiBold" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Persona" FontWeight="SemiBold" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="ID Admin" FontWeight="SemiBold" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="Acciones" FontWeight="SemiBold" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ListBox ItemsSource="{Binding Administradores}" Background="Transparent" BorderThickness="0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="models:Administrador">
                                                    <Border Background="Transparent" Padding="12,10" Margin="0">
                                                        <Grid ColumnDefinitions="*,*,*,Auto">
                                                            <TextBlock Grid.Column="0" Text="{Binding Usuario}" Foreground="{StaticResource BrushBlanco}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Persona.NombreCompleto}" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding IdAdmin}" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                                <Button Command="{Binding $parent[ItemsControl].DataContext.EditarAdminCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="{StaticResource BrushAzulMarinoMedio}"
                                                                        Foreground="{StaticResource BrushBlanco}"
                                                                        Height="28" Width="28"
                                                                        CornerRadius="2"
                                                                        ToolTip.Tip="Editar">
                                                                    <Image Source="avares://ChecadorSSSD/Assets/Icons/edit.png" Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                </Button>
                                                                <Button Command="{Binding $parent[ItemsControl].DataContext.EliminarAdminCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="{StaticResource BrushRojoError}"
                                                                        Foreground="{StaticResource BrushBlanco}"
                                                                        Height="28" Width="28"
                                                                        CornerRadius="2"
                                                                        ToolTip.Tip="Eliminar">
                                                                    <Image Source="avares://ChecadorSSSD/Assets/Icons/delete.png" Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ListBox>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                        <Grid Grid.Column="1" Margin="16,0,0,0">
                            <Border Background="{StaticResource BrushAzulFondoCont}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="4" Padding="20">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="{Binding TituloFormularioAdmin}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushBlanco}" Margin="0,0,0,8"/>
                                    <StackPanel Spacing="4"><TextBlock Text="Usuario" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Medium"/><TextBox Text="{Binding AdminEnEdicion.Usuario}" PlaceholderText="Usuario" Height="36" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" Padding="10,0" VerticalContentAlignment="Center"/></StackPanel>
                                    <StackPanel Spacing="4"><TextBlock Text="Contrasenia" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Medium"/><TextBox Text="{Binding AdminEnEdicion.Contrasenia}" PasswordChar="*" PlaceholderText="Contrasenia" Height="36" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" Padding="10,0" VerticalContentAlignment="Center"/></StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Persona" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Medium"/>
                                        <ComboBox ItemsSource="{Binding PersonasDisponiblesAdmin}" 
                                                  SelectedItem="{Binding PersonaSeleccionadaAdmin}" 
                                                  Height="36" 
                                                  Background="{StaticResource BrushAzulMarino}" 
                                                  BorderBrush="{StaticResource BrushCappuccino}" 
                                                  BorderThickness="1" 
                                                  Foreground="{StaticResource BrushBlanco}" 
                                                  CornerRadius="2" 
                                                  Padding="10,0" 
                                                  VerticalContentAlignment="Center">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="models:Personas">
                                                    <TextBlock Text="{Binding NombreCompleto}" Foreground="{StaticResource BrushBlanco}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
                                        <Button Command="{Binding GuardarAdminCommand}" Content="Guardar" Height="40" Padding="24,0" Background="{StaticResource BrushDoradoUniversidad}" Foreground="{StaticResource BrushNegro}" CornerRadius="2" FontWeight="SemiBold" HorizontalAlignment="Stretch"/>
                                        <Button Command="{Binding CancelarAdminCommand}" Content="Cancelar" Height="40" Padding="24,0" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" Foreground="{StaticResource BrushBlanco}" CornerRadius="2" FontWeight="SemiBold" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
