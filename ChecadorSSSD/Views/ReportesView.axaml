<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ChecadorSSSD.Views.ReportesView"
             x:DataType="vm:ReportesViewModel"
             xmlns:vm="clr-namespace:ChecadorSSSD.ViewModels"
             xmlns:models="clr-namespace:ChecadorSSSD.Services"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="20">
        <!-- Encabezado (Row 0) -->
        <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,16">
            <TextBlock Text="Reportes de Asistencia" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF"/>
            <TextBlock Text="Genera reportes de asistencia por periodo, tipo de usuario y tipo de reporte" FontSize="13" Foreground="#A6A6B0"/>
        </StackPanel>

        <!-- Filtros responsivos (Row 1) -->
        <Border Grid.Row="1" Background="#1E1E2E" CornerRadius="12" Padding="16" Margin="0,0,0,12">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <!-- Tipo de reporte -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Tipo de reporte" Foreground="#A6A6B0" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding TiposReporte}"
                                  SelectedItem="{Binding TipoReporteSeleccionado}"
                                  Height="36"
                                  Width="200"
                                  Background="#25253A"
                                  Foreground="#FFFFFF"
                                  CornerRadius="6"
                                  Padding="10,0"
                                  VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Fecha inicio -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Fecha inicio" Foreground="#A6A6B0" FontSize="11"/>
                        <DatePicker SelectedDate="{Binding FechaInicio}"
                                    Background="#25253A"
                                    Foreground="#FFFFFF"
                                    CornerRadius="6"
                                    Height="36"/>
                    </StackPanel>

                    <!-- Fecha fin -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Fecha fin" Foreground="#A6A6B0" FontSize="11"/>
                        <DatePicker SelectedDate="{Binding FechaFin}"
                                    Background="#25253A"
                                    Foreground="#FFFFFF"
                                    CornerRadius="6"
                                    Height="36"/>
                    </StackPanel>

                    <!-- Tipo de usuario -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Tipo de usuario" Foreground="#A6A6B0" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding TiposUsuario}"
                                  SelectedItem="{Binding TipoPersonaSeleccionado}"
                                  PlaceholderText="Todos"
                                  Height="36"
                                  Width="160"
                                  Background="#25253A"
                                  Foreground="#FFFFFF"
                                  CornerRadius="6"
                                  Padding="10,0"
                                  VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Botón generar -->
                    <Button Content="Generar Reporte"
                            Command="{Binding GenerarCommand}"
                            Height="36"
                            Padding="20,0"
                            Margin="0,0,8,8"
                            Background="#2196F3"
                            Foreground="#FFFFFF"
                            CornerRadius="8"
                            FontWeight="SemiBold"
                            VerticalAlignment="Bottom"/>

                    <!-- Botón exportar Excel -->
                    <Button Content="Exportar Excel"
                            Command="{Binding ExportarExcelCommand}"
                            Height="36"
                            Padding="20,0"
                            Background="#4CAF50"
                            Foreground="#FFFFFF"
                            CornerRadius="8"
                            FontWeight="SemiBold"
                            VerticalAlignment="Bottom"/>
                </WrapPanel>
            </ScrollViewer>
        </Border>

        <!-- Buscador (Row 2) -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Buscar:" Foreground="#A6A6B0" FontSize="13" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding Busqueda}"
                             PlaceholderText="Buscar por nombre o matricula..."
                             Width="320"
                             Height="32"
                             VerticalContentAlignment="Center"
                             Background="#25253A"
                             Foreground="#FFFFFF"
                             CaretBrush="#FFFFFF"
                             CornerRadius="6"
                             Padding="8,0"
                             FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Anterior"
                            Command="{Binding PaginaAnteriorCommand}"
                            IsEnabled="{Binding PaginaAnteriorPuedeEjecutarse}"
                            Padding="8,2"
                            Background="Transparent"
                            Foreground="#A6A6B0"
                            BorderBrush="#33334D"
                            BorderThickness="0"
                            FontSize="12"/>
                    <TextBlock Text="{Binding RangoPaginaText}" Foreground="#A6A6B0" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="8,0"/>
                    <Button Content="Siguiente"
                            Command="{Binding PaginaSiguienteCommand}"
                            IsEnabled="{Binding PaginaSiguientePuedeEjecutarse}"
                            Padding="8,2"
                            Background="Transparent"
                            Foreground="#A6A6B0"
                            BorderBrush="#33334D"
                            BorderThickness="0"
                            FontSize="12"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Mensaje (dentro de Row 3 ocupa su propio espacio) -->
        <Border Grid.Row="3"
                Background="#F44336"
                CornerRadius="6"
                Padding="12,8"
                IsVisible="{Binding MostrarMensaje}"
                Margin="0,0,0,12">
            <TextBlock Text="{Binding Mensaje}"
                       FontSize="13"
                       Foreground="#FFFFFF"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- =========================== -->
        <!-- Resultados TABLA DE HORAS   -->
        <!-- =========================== -->
        <Grid Grid.Row="3" IsVisible="{Binding MostrarResultadosHoras}">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="#25253A" CornerRadius="8,8,0,0" Padding="12,8">
                    <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="NombreCompleto" Grid.Column="0" Content="Nombre Completo" Foreground="#A6A6B0" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="Matricula" Grid.Column="1" Content="Matricula" Foreground="#A6A6B0" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="Rol" Grid.Column="2" Content="Rol" Foreground="#A6A6B0" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="TotalAsistencias" Grid.Column="3" Content="Asistencias" Foreground="#A6A6B0" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="TotalEntradas" Grid.Column="4" Content="Entradas" Foreground="#A6A6B0" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="TotalSalidas" Grid.Column="5" Content="Salidas" Foreground="#A6A6B0" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="HorasAcumuladas" Grid.Column="6" Content="Horas" Foreground="#A6A6B0" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ResultadosPaginadosHoras}" Background="Transparent">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:ReporteItem">
                                <Border Background="#25253A" Padding="12,8" BorderBrush="#33334D" BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                                        <TextBlock Grid.Column="0" Text="{Binding NombreCompleto}" Foreground="#FFFFFF" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Matricula}" Foreground="#A6A6B0" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <Border Grid.Column="2" Background="#4CAF50" CornerRadius="4" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Rol}" Foreground="#FFFFFF" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="{Binding TotalAsistencias}" Foreground="#4CAF50" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding TotalEntradas}" Foreground="#F44336" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="{Binding TotalSalidas}" Foreground="#2196F3" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding HorasAcumuladas}" Foreground="#FFFFFF" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text=" hrs" Foreground="#666680" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- =========================== -->
        <!-- Resultados TABLA PERSONAS   -->
        <!-- =========================== -->
        <Grid Grid.Row="3" IsVisible="{Binding MostrarResultadosUsuarios}">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="#25253A" CornerRadius="8,8,0,0" Padding="12,8">
                    <Grid ColumnDefinitions="*,*,*,*,*,*,*,*,*,*">
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="Matricula" Grid.Column="0" Content="Matricula" Foreground="#A6A6B0" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="Nombre" Grid.Column="1" Content="Nombre" Foreground="#A6A6B0" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="ApellidoPaterno" Grid.Column="2" Content="Apellido P" Foreground="#A6A6B0" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="ApellidoMaterno" Grid.Column="3" Content="Apellido M" Foreground="#A6A6B0" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="Fecha" Grid.Column="4" Content="Fecha" Foreground="#A6A6B0" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <TextBlock Grid.Column="5" Text="Hora Entr" Foreground="#A6A6B0" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="Hora Sal" Foreground="#A6A6B0" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="HorasDiarias" Grid.Column="7" Content="Horas Dia" Foreground="#A6A6B0" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <TextBlock Grid.Column="8" Text="Clasificacion" Foreground="#A6A6B0" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="9" Text="Horas Trabajadas" Foreground="#A6A6B0" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ResultadosPaginadosUsuarios}" Background="Transparent">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:ReporteDetalleItem">
                                <Border Background="#25253A" Padding="12,8" BorderBrush="#33334D" BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="*,*,*,*,*,*,*,*,*,*">
                                        <TextBlock Grid.Column="0" Text="{Binding Matricula}" Foreground="#FFFFFF" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="100"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Nombre}" Foreground="#FFFFFF" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="100"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ApellidoPaterno}" Foreground="#A6A6B0" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="100"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ApellidoMaterno}" Foreground="#A6A6B0" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="100"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Fecha, StringFormat={}{0:yyyy-MM-dd}}" Foreground="#FFFFFF" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="{Binding HoraEntrada}" Foreground="#2196F3" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="6" Text="{Binding HoraSalida}" Foreground="#F44336" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="7" Text="{Binding HorasDiarias}" Foreground="#FFFFFF" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <Border Grid.Column="8" Background="#FFC107" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ClasificacionHoras}" Foreground="#000000" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Grid.Column="9" Text="{Binding HorasTrabajadas}" Foreground="#FFFFFF" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>