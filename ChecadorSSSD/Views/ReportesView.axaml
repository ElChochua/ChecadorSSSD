<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ChecadorSSSD.Views.ReportesView"
             x:DataType="vm:ReportesViewModel"
             xmlns:vm="clr-namespace:ChecadorSSSD.ViewModels"
             xmlns:models="clr-namespace:ChecadorSSSD.Services"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <Grid RowDefinitions="Auto,*" Margin="20" Background="{StaticResource BrushAzulMarino}">
        <!-- Filtros + Busqueda + Botones de accion (Row 0) -->
        <Border Grid.Row="0" Background="{StaticResource BrushAzulFondoCont}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,12">
            <StackPanel Spacing="12">
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <!-- Buscar empleado -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Buscar Empleado" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11"/>
                        <TextBox Text="{Binding Busqueda}"
                                 PlaceholderText="Nombre o matricula..."
                                 Width="200"
                                 Height="36"
                                 Background="{StaticResource BrushAzulMarino}"
                                 BorderBrush="{StaticResource BrushCappuccino}"
                                 BorderThickness="1"
                                 Foreground="{StaticResource BrushBlanco}"
                                 CaretBrush="{StaticResource BrushBlanco}"
                                 CornerRadius="2"
                                 Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 FontSize="12"/>
                    </StackPanel>

                    <!-- Tipo de reporte -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Tipo de Reporte" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding TiposReporte}"
                                  SelectedItem="{Binding TipoReporteSeleccionado}"
                                  Height="36"
                                  Width="200"
                                  Background="{StaticResource BrushAzulMarino}"
                                  Foreground="{StaticResource BrushBlanco}"
                                  CornerRadius="2"
                                  Padding="10,0"
                                  VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Fecha inicio -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Desde" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11"/>
                        <DatePicker SelectedDate="{Binding FechaInicio}"
                                    Background="{StaticResource BrushAzulMarino}"
                                    Foreground="{StaticResource BrushBlanco}"
                                    CornerRadius="2"
                                    Height="36"/>
                    </StackPanel>

                    <!-- Fecha fin -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Hasta" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11"/>
                        <DatePicker SelectedDate="{Binding FechaFin}"
                                    Background="{StaticResource BrushAzulMarino}"
                                    Foreground="{StaticResource BrushBlanco}"
                                    CornerRadius="4"
                                    Height="36"
                                    BorderBrush="{StaticResource BrushCappuccino}"
                                    BorderThickness="1"/>
                    </StackPanel>

                    <!-- Tipo de usuario -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Tipo de Usuario" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding TiposUsuario}"
                                  SelectedItem="{Binding TipoPersonaSeleccionado}"
                                  PlaceholderText="Todos"
                                  Height="36"
                                  Width="160"
                                  Background="{StaticResource BrushAzulMarino}"
                                  Foreground="{StaticResource BrushBlanco}"
                                  CornerRadius="2"
                                  Padding="10,0"
                                  VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Botones Generar + Exportar -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <Button Content="Generar"
                                Command="{Binding GenerarCommand}"
                                Height="36"
                                Padding="20,0"
                                Background="{StaticResource BrushDoradoUniversidad}"
                                Foreground="{StaticResource BrushNegro}"
                                CornerRadius="4"
                                FontWeight="SemiBold"
                                VerticalAlignment="Bottom">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Image Source="avares://ChecadorSSSD/Assets/Icons/generatechart.png" Width="18" Height="18"/>
                                    <TextBlock Text="Generar" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button.Content>
                        </Button>

                        <Button Command="{Binding ExportarExcelCommand}"
                                Height="36"
                                Padding="20,0"
                                Background="{StaticResource BrushAzulMarino}" 
                                BorderBrush="{StaticResource BrushCappuccino}"
                                BorderThickness="1"
                                Foreground="{StaticResource BrushBlanco}"
                                CornerRadius="4"
                                FontWeight="SemiBold"
                                VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="avares://ChecadorSSSD/Assets/Icons/export.png" Width="18" Height="18"/>
                                <TextBlock Text="Exportar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Row 1: Tablas de reportes con "Mostrando X registros" -->
        <Border Grid.Row="1" Background="{StaticResource BrushAzulFondoCont}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="4" Padding="0" IsVisible="{Binding MostrarResultados}">
            <Grid RowDefinitions="Auto,*">
                <!-- Top info -->
                <Border Grid.Row="0" Background="{StaticResource BrushAzulMarinoMedio}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="0,0,0,1" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="avares://ChecadorSSSD/Assets/Icons/tablechart.png" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Resultados de Reporte" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource BrushDoradoUniversidad}" VerticalAlignment="Center"/>
                        <TextBlock Text="/" Margin="6,0" Foreground="{StaticResource BrushGrisTextoClaro}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CantidadRegistrosText}" Foreground="{StaticResource BrushBlanco}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Tablas -->
                <Grid Grid.Row="1" Background="Transparent">
    <Grid.RowDefinitions>
    </Grid.RowDefinitions>
                    <!-- TABLA HORAS -->
                    <Grid IsVisible="{Binding EsReporteHoras}"
                          RowDefinitions="Auto,*">
                        <!-- Headers clickeables -->
                        <Border Grid.Row="0" Background="{StaticResource BrushAzulMarinoMedio}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="0,0,0,1" Padding="12,8">
                            <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                                <Button Grid.Column="0" Content="Nombre Completo" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="NombreCompleto"/>
                                <Button Grid.Column="1" Content="Matricula" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="Matricula"/>
                                <Button Grid.Column="2" Content="Rol" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="Rol"/>
                                <Button Grid.Column="3" Content="Asistencias" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="Asistencias"/>
                                <Button Grid.Column="4" Content="Entradas" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="Entradas"/>
                                <Button Grid.Column="5" Content="Salidas" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="Salidas"/>
                                <Button Grid.Column="6" Content="Total Hrs" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="TotalHoras"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ResultadosPaginadosHoras}" Background="Transparent">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models:ReporteItem">
                                        <Border Background="{StaticResource BrushAzulMarinoMedio}" Padding="12,8" BorderBrush="{StaticResource BrushAzulMarinoClaro}" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                                                <TextBlock Grid.Column="0" Text="{Binding NombreCompleto}" Foreground="{StaticResource BrushBlanco}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Matricula}" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                <Border Grid.Column="2" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Rol}" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="10" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Grid.Column="3" Text="{Binding TotalAsistencias}" Foreground="{StaticResource BrushVerdeExito}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="4" Text="{Binding TotalEntradas}" Foreground="{StaticResource BrushRojoError}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="5" Text="{Binding TotalSalidas}" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding HorasAcumuladas}" Foreground="{StaticResource BrushBlanco}" FontSize="12" FontWeight="SemiBold"/>
                                                    <TextBlock Text=" hrs" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- TABLA USUARIOS -->
                    <Grid IsVisible="{Binding EsReporteUsuarios}"
                          RowDefinitions="Auto,*">
                        <!-- Headers clickeables -->
                        <Border Grid.Row="0" Background="{StaticResource BrushAzulMarinoMedio}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="0,0,0,1" Padding="12,8">
                            <Grid ColumnDefinitions="*,*,*,*,*,*,*,*">
                                <Button Grid.Column="0" Content="Nombre Completo" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="NombreCompletoUsuarios"/>
                                <Button Grid.Column="1" Content="Matricula" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="MatriculaUsuarios"/>
                                <Button Grid.Column="2" Content="Rol" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="RolUsuarios"/>
                                <Button Grid.Column="3" Content="Dia" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="Fecha"/>
                                <Button Grid.Column="4" Content="Hora Entrada" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="HoraEntrada"/>
                                <Button Grid.Column="5" Content="Hora Salida" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="HoraSalida"/>
                                <Button Grid.Column="6" Content="Horas Trabajadas" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="HorasTrabajadas"/>
                                <Button Grid.Column="7" Content="Clasificacion" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent" Command="{Binding OrdenarHeaderCommand}" CommandParameter="Clasificacion"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Orientation="Vertical" Spacing="0" Background="Transparent">
                                <ItemsControl ItemsSource="{Binding ResultadosPaginadosUsuarios}" Background="Transparent">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="models:ReporteDetalleItem">
                                            <Border Background="{StaticResource BrushAzulMarinoMedio}" Padding="12,8" BorderBrush="{StaticResource BrushAzulMarinoClaro}" BorderThickness="0,0,0,1">
                                                <Grid ColumnDefinitions="*,*,*,*,*,*,*,*">
                                                    <TextBlock Grid.Column="0" Text="{Binding NombreCompleto}" Foreground="{StaticResource BrushBlanco}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="250"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Matricula}" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Border Grid.Column="2" Background="{StaticResource BrushAzulMarino}" BorderBrush="{StaticResource BrushCappuccino}" BorderThickness="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Rol}" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="10" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="3" Text="{Binding Fecha, StringFormat={}{0:yyyy-MM-dd}}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding HoraEntrada}" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                                    <TextBlock Grid.Column="5" Text="{Binding HoraSalida}" Foreground="{StaticResource BrushRojoError}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                                    <TextBlock Grid.Column="6" Text="{Binding HorasTrabajadas}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Border Grid.Column="7" Background="{StaticResource BrushDoradoUniversidad}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ClasificacionHoras}" Foreground="{StaticResource BrushNegro}" FontSize="10" FontWeight="SemiBold"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
