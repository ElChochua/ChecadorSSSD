<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ChecadorSSSD.Views.ReportesView"
             x:DataType="vm:ReportesViewModel"
             xmlns:vm="clr-namespace:ChecadorSSSD.ViewModels"
             xmlns:models="clr-namespace:ChecadorSSSD.Services"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="20" Background="{StaticResource BrushAzulMarino}">
        <!-- Encabezado (Row 0) -->
        <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,16">
            <TextBlock Text="Reportes de Asistencia" FontSize="24" FontWeight="Bold" Foreground="{StaticResource BrushDoradoUniversidad}"/>
            <TextBlock Text="Genera reportes de asistencia por periodo, tipo de usuario y tipo de reporte" FontSize="13" Foreground="{StaticResource BrushGrisTextoClaro}"/>
        </StackPanel>

        <!-- Filtros + Busqueda + Botones de accion (Row 1) -->
        <Border Grid.Row="1" Background="{StaticResource BrushAzulMarinoMedio}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
            <StackPanel Spacing="12">
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <!-- Tipo de reporte -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Tipo de reporte" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding TiposReporte}"
                                  SelectedItem="{Binding TipoReporteSeleccionado}"
                                  Height="36"
                                  Width="200"
                                  Background="{StaticResource BrushAzulMarino}"
                                  Foreground="{StaticResource BrushBlanco}"
                                  CornerRadius="6"
                                  Padding="10,0"
                                  VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Fecha inicio -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Fecha inicio" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11"/>
                        <DatePicker SelectedDate="{Binding FechaInicio}"
                                    Background="{StaticResource BrushAzulMarino}"
                                    Foreground="{StaticResource BrushBlanco}"
                                    CornerRadius="6"
                                    Height="36"/>
                    </StackPanel>

                    <!-- Fecha fin -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Fecha fin" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11"/>
                        <DatePicker SelectedDate="{Binding FechaFin}"
                                    Background="{StaticResource BrushAzulMarino}"
                                    Foreground="{StaticResource BrushBlanco}"
                                    CornerRadius="6"
                                    Height="36"/>
                    </StackPanel>

                    <!-- Tipo de usuario -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Tipo de usuario" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding TiposUsuario}"
                                  SelectedItem="{Binding TipoPersonaSeleccionado}"
                                  PlaceholderText="Todos"
                                  Height="36"
                                  Width="160"
                                  Background="{StaticResource BrushAzulMarino}"
                                  Foreground="{StaticResource BrushBlanco}"
                                  CornerRadius="6"
                                  Padding="10,0"
                                  VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Buscar -->
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Buscar" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11"/>
                        <TextBox Text="{Binding Busqueda}"
                                 PlaceholderText="Buscar por nombre o matricula..."
                                 Width="280"
                                 Height="36"
                                 VerticalContentAlignment="Center"
                                 Background="{StaticResource BrushAzulMarino}"
                                 Foreground="{StaticResource BrushBlanco}"
                                 CaretBrush="{StaticResource BrushBlanco}"
                                 CornerRadius="6"
                                 Padding="10,0"
                                 FontSize="12"/>
                    </StackPanel>
                </WrapPanel>

                <!-- Botones de accion alineados -->
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left" Margin="0,4,0,0">
                    <Button Content="Generar Reporte"
                            Command="{Binding GenerarCommand}"
                            Height="36"
                            Padding="20,0"
                            Background="{StaticResource BrushDoradoUniversidad}"
                            Foreground="{StaticResource BrushNegro}"
                            CornerRadius="8"
                            FontWeight="SemiBold"
                            VerticalAlignment="Bottom"/>

                    <Button Content="Exportar Excel"
                            Command="{Binding ExportarExcelCommand}"
                            Height="36"
                            Padding="20,0"
                            Background="{StaticResource BrushVerdeExito}"
                            Foreground="{StaticResource BrushBlanco}"
                            CornerRadius="8"
                            FontWeight="SemiBold"
                            VerticalAlignment="Bottom"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Paginador (Row 2) -->
        <Border Grid.Row="2" Background="{StaticResource BrushAzulMarinoMedio}" CornerRadius="8" Padding="8,4" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <Button Content="Anterior"
                        Command="{Binding PaginaAnteriorCommand}"
                        Padding="8,2"
                        Background="Transparent"
                        Foreground="{StaticResource BrushGrisTextoClaro}"
                        BorderBrush="{StaticResource BrushAzulMarinoClaro}"
                        BorderThickness="0"
                        FontSize="12"/>
                <TextBlock Text="{Binding RangoPaginaText}" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="8,0"/>
                    <Button Content="Siguiente"
                            Command="{Binding PaginaSiguienteCommand}"
                            Padding="8,2"
                            Background="Transparent"
                            Foreground="{StaticResource BrushGrisTextoClaro}"
                            BorderBrush="{StaticResource BrushAzulMarinoClaro}"
                            BorderThickness="0"
                            FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Mensaje -->
        <Border Grid.Row="3"
                Background="{StaticResource BrushRojoError}"
                CornerRadius="6"
                Padding="12,8"
                IsVisible="{Binding MostrarMensaje}"
                Margin="0,0,0,12">
            <TextBlock Text="{Binding Mensaje}"
                       FontSize="13"
                       Foreground="{StaticResource BrushBlanco}"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- =========================== -->
        <!-- Resultados TABLA DE HORAS   -->
        <!-- =========================== -->
        <Grid Grid.Row="3" IsVisible="{Binding MostrarResultadosHoras}">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="{StaticResource BrushAzulMarinoMedio}" CornerRadius="8,8,0,0" Padding="12,8">
                    <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="NombreCompleto" Grid.Column="0" Content="Nombre Completo" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="Matricula" Grid.Column="1" Content="Matricula" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="Rol" Grid.Column="2" Content="Rol" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="TotalAsistencias" Grid.Column="3" Content="Asistencias" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="TotalEntradas" Grid.Column="4" Content="Entradas" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="TotalSalidas" Grid.Column="5" Content="Salidas" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="HorasAcumuladas" Grid.Column="6" Content="Horas" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" FontWeight="Bold" Padding="4,8" HorizontalAlignment="Center" Background="Transparent"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ResultadosPaginadosHoras}" Background="Transparent">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:ReporteItem">
                                <Border Background="{StaticResource BrushAzulMarinoMedio}" Padding="12,8" BorderBrush="{StaticResource BrushAzulMarinoClaro}" BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                                        <TextBlock Grid.Column="0" Text="{Binding NombreCompleto}" Foreground="{StaticResource BrushBlanco}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Matricula}" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <Border Grid.Column="2" Background="{StaticResource BrushVerdeExito}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Rol}" Foreground="{StaticResource BrushBlanco}" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="{Binding TotalAsistencias}" Foreground="{StaticResource BrushVerdeExito}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding TotalEntradas}" Foreground="{StaticResource BrushRojoError}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="{Binding TotalSalidas}" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding HorasAcumuladas}" Foreground="{StaticResource BrushBlanco}" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text=" hrs" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- =========================== -->
        <!-- Resultados TABLA PERSONAS   -->
        <!-- =========================== -->
        <Grid Grid.Row="3" IsVisible="{Binding MostrarResultadosUsuarios}">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="{StaticResource BrushAzulMarinoMedio}" CornerRadius="8,8,0,0" Padding="12,8">
                    <Grid ColumnDefinitions="*,*,*,*,*,*,*,*,*,*">
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="Matricula" Grid.Column="0" Content="Matricula" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="Nombre" Grid.Column="1" Content="Nombre" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="ApellidoPaterno" Grid.Column="2" Content="Apellido P" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="ApellidoMaterno" Grid.Column="3" Content="Apellido M" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="Fecha" Grid.Column="4" Content="Fecha" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <TextBlock Grid.Column="5" Text="Hora Entr" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="Hora Sal" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                        <Button Command="{Binding OrdenarHeaderCommand}" CommandParameter="HorasDiarias" Grid.Column="7" Content="Horas Dia" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center" Background="Transparent"/>
                        <TextBlock Grid.Column="8" Text="Clasificacion" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="9" Text="Horas Trabajadas" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="Bold" Padding="2,8" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ResultadosPaginadosUsuarios}" Background="Transparent">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:ReporteDetalleItem">
                                <Border Background="{StaticResource BrushAzulMarinoMedio}" Padding="12,8" BorderBrush="{StaticResource BrushAzulMarinoClaro}" BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="*,*,*,*,*,*,*,*,*,*">
                                        <TextBlock Grid.Column="0" Text="{Binding Matricula}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="100"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Nombre}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="100"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ApellidoPaterno}" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="100"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ApellidoMaterno}" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="100"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Fecha, StringFormat={}{0:yyyy-MM-dd}}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="{Binding HoraEntrada}" Foreground="{StaticResource BrushDoradoUniversidad}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="6" Text="{Binding HoraSalida}" Foreground="{StaticResource BrushRojoError}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="7" Text="{Binding HorasDiarias}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <Border Grid.Column="8" Background="{StaticResource BrushDoradoUniversidad}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ClasificacionHoras}" Foreground="{StaticResource BrushNegro}" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Grid.Column="9" Text="{Binding HorasTrabajadas}" Foreground="{StaticResource BrushBlanco}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
