<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ChecadorSSSD.Views.ChecadorView"
             x:DataType="vm:ChecadorViewModel"
             xmlns:vm="clr-namespace:ChecadorSSSD.ViewModels"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <Grid RowDefinitions="Auto,Auto,Auto,*"
          Background="{StaticResource BrushAzulMarino}">

        <!-- Row 0: Reloj grande -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushAzulFondoCont}"
                BorderBrush="{StaticResource BrushCappuccino}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="32,16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{Binding HoraActual}"
                           FontSize="96"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrushDoradoUniversidad}"
                           HorizontalAlignment="Center"
                           FontFamily="{StaticResource InterFontFamily}"/>
                           <TextBlock Text="{Binding FechaActual}"
                           FontSize="20"
                           Foreground="{StaticResource BrushGrisTextoClaro}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           FontFamily="{StaticResource InterFontFamily}" />
            </StackPanel>
        </Border>

        <!-- Row 1: Imágenes Universidad + Lugar -->
        <Border Grid.Row="1"
                Padding="16"
                Margin="0,0,0,16">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal"
                            Spacing="24"
                            HorizontalAlignment="Center">
                    <Border Background="{StaticResource BrushAzulMarino}"
                            CornerRadius="2"
                            Padding="16"
                            Width="200"
                            Height="140"
                            IsVisible="{Binding HasImagenUniversidad}">
                        <Image Source="{Binding ImagenUniversidad}"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>
                    <Border Background="{StaticResource BrushAzulMarino}"
                            CornerRadius="2"
                            Padding="16"
                            Width="200"
                            Height="140"
                            IsVisible="{Binding HasImagenLugar}">
                        <Image Source="{Binding ImagenLugar}"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Row 2: Mensaje de estado -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushCappuccino}"
                CornerRadius="4"
                Padding="1"
                Margin="0,0,0,16"
                IsVisible="{Binding MostrarMensaje}"
                HorizontalAlignment="Stretch">
            <Border Background="{StaticResource BrushAzulFondoCont}">
                <Grid>
                    <Border Background="#2E7D32" CornerRadius="4" Padding="16,12"
                            IsVisible="{Binding EsError, Converter={StaticResource InverseBoolConverter}}" />
                    <Border Background="#C0392B" CornerRadius="4" Padding="16,12"
                            IsVisible="{Binding EsError}" />
                    <TextBlock Text="{Binding Mensaje}"
                               FontSize="14"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="{StaticResource BrushBlanco}"/>
                </Grid>
            </Border>
        </Border>

        <!-- Row 3: Input Matricula -->
        <Border Grid.Row="3"
                Background="{StaticResource BrushAzulFondoCont}"
                BorderBrush="{StaticResource BrushCappuccino}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="48,32"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MaxWidth="600">
            <StackPanel Spacing="24">
                <TextBlock Text="Introduce tu matricula"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushBlanco}"
                           HorizontalAlignment="Left"/>

                <TextBox Text="{Binding Matricula}"
                         PlaceholderText="Matricula"
                         Height="50"
                         FontSize="24"
                         CornerRadius="2"
                         Background="{StaticResource BrushAzulMarino}"
                         BorderBrush="{StaticResource BrushCappuccino}"
                         BorderThickness="1"
                         Foreground="{StaticResource BrushBlanco}"
                         CaretBrush="{StaticResource BrushBlanco}"
                         Padding="20,0"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         HorizontalAlignment="Stretch" />

                <Button Content="Marcar Entrada/Salida"
                        Command="{Binding RegistrarCommand}"
                        Height="50"
                        FontSize="18"
                        FontWeight="Bold"
                        CornerRadius="2"
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource BrushDoradoUniversidad}"
                        Foreground="{StaticResource BrushNegro}"
                        Margin="0,8,0,0"/>

                <!-- Seccion de estado del lector de huella -->
                <Border Background="{StaticResource BrushAzulMarino}"
                        BorderBrush="{StaticResource BrushCappuccino}"
                        BorderThickness="0,1,0,0"
                        Padding="8,8,8,0"
                        Margin="0,40,0,0">
                    <StackPanel Spacing="8" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Source="avares://ChecadorSSSD/Assets/Icons/fingerprint.png"
                               Width="20"
                               Height="20"
                               VerticalAlignment="Center" />
                        <TextBlock Text="{Binding EstadoLector}"
                                   FontSize="13"
                                   Foreground="{StaticResource BrushGrisTextoClaro}"
                                   HorizontalAlignment="Center"/>
                        <!-- Estado activo -->
                        <Border Background="{StaticResource BrushVerdeExito}"
                                Padding="12,6"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding LectorHuellaConectado}">
                            <TextBlock Text="ACTIVO"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushBlanco}"/>
                        </Border>
                        <!-- Estado no disponible -->
                        <Border Background="{StaticResource BrushAzulFondoCont}"
                                BorderBrush="{StaticResource BrushCappuccino}"
                                BorderThickness="1"
                                Padding="12,6"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding !LectorHuellaConectado}">
                            <TextBlock Text="NO DISPONIBLE"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushGrisTextoClaro}"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
