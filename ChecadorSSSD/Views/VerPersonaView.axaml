<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ChecadorSSSD.Views.VerPersonaView"
        xmlns:models="clr-namespace:ChecadorSSSD.Models"
        x:DataType="models:Personas"
        Title="Detalle de Persona"
        Width="500"
        Height="560"
        Background="{StaticResource BrushAzulMarino}"
        WindowStartupLocation="CenterScreen">
    <Grid RowDefinitions="Auto,*,Auto" Margin="24">
        <TextBlock Grid.Row="0" Text="DETALLE DE PERSONA" FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrushDoradoUniversidad}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
            <!-- FOTO -->
            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="Foto:" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="SemiBold"/>
                <Border Background="{StaticResource BrushAzulMarinoClaro}" CornerRadius="12" Width="120" Height="120" HorizontalAlignment="Center" Margin="0,8">
                    <Image Name="FotoImagen" Stretch="Uniform" />
                </Border>
            </StackPanel>
            <StackPanel Grid.Row="1" Spacing="4">
                <TextBlock Text="Nombre:" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Nombre}" Foreground="{StaticResource BrushBlanco}" FontSize="14"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Spacing="4">
                <TextBlock Text="Apellido Paterno:" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding ApellidoPaterno}" Foreground="{StaticResource BrushBlanco}" FontSize="14"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Spacing="4">
                <TextBlock Text="Apellido Materno:" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding ApellidoMaterno}" Foreground="{StaticResource BrushBlanco}" FontSize="14"/>
            </StackPanel>
            <StackPanel Grid.Row="4" Spacing="4">
                <TextBlock Text="Matricula:" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Matricula}" Foreground="{StaticResource BrushBlanco}" FontSize="14"/>
            </StackPanel>
            <StackPanel Grid.Row="5" Spacing="4">
                <TextBlock Text="Tipo de Persona:" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding TipoPersona}" Foreground="{StaticResource BrushBlanco}" FontSize="14"/>
            </StackPanel>
            <StackPanel Grid.Row="6" Spacing="4">
                <TextBlock Text="ID:" Foreground="{StaticResource BrushGrisTextoClaro}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding IdPersona}" Foreground="{StaticResource BrushBlanco}" FontSize="14"/>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content=" Copiar Matricula " Click="CopiarMatricula_Click" Padding="12,8" Background="{StaticResource BrushDoradoUniversidad}" Foreground="{StaticResource BrushNegro}" FontWeight="SemiBold" CornerRadius="8" HorizontalAlignment="Center"/>
            <Button Content=" Cerrar " IsDefault="True" IsCancel="True" Padding="12,8" Background="{StaticResource BrushAzulMarinoClaro}" Foreground="{StaticResource BrushBlanco}" FontWeight="SemiBold" CornerRadius="8" HorizontalAlignment="Center" Click="Cerrar_Click"/>
        </StackPanel>
    </Grid>
</Window>
