<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ChecadorSSSD.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        xmlns:vm="clr-namespace:ChecadorSSSD.ViewModels"
        xmlns:views="clr-namespace:ChecadorSSSD.Views"
        Title="Checador SSSD"
        WindowState="FullScreen"
        Background="{StaticResource BrushAzulMarino}"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="250,*">
        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{StaticResource BrushAzulMarinoSidebar}"
                BorderBrush="{StaticResource BrushCappuccino}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Parte superior: Logo + Carrusel -->
                <Grid Grid.Row="0" RowDefinitions="Auto,Auto">
                    <!-- Logo del programa -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushAzulFondoCont}"
                            CornerRadius="4"
                            Padding="12"
                            Margin="12,12,12,8"
                            BorderBrush="{StaticResource BrushCappuccino}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                            <Image Source="{Binding LogoSidebar}"
                                   Width="28"
                                   Height="28"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding HasLogoSidebar}"/>
                            <TextBlock Text="Checador"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BrushDoradoUniversidad}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Carrusel compacto -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BrushAzulFondoCont}"
                            CornerRadius="4"
                            Padding="8"
                            Margin="12,0,12,8"
                            BorderBrush="{StaticResource BrushCappuccino}"
                            BorderThickness="1"
                            MaxHeight="140">
                        <Grid RowDefinitions="Auto,*">
                            <TextBlock Grid.Row="0"
                                       Text="{Binding CarruselTituloActual}"
                                       Foreground="{StaticResource BrushDoradoUniversidad}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                            <Border Grid.Row="1"
                                    Background="{StaticResource BrushAzulMarino}"
                                    CornerRadius="2">
                                <Image Source="{Binding CarruselImagenActual}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Centro: Navegacion -->
                <StackPanel Grid.Row="1"
                            Orientation="Vertical"
                            Spacing="4"
                            VerticalAlignment="Center"
                            Margin="12,0">
                    <Button Command="{Binding NavigateToChecadorCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="16,12"
                            Background="Transparent"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Image Source="avares://ChecadorSSSD/Assets/Icons/clock.png" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock Text="Checador"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushBlanco}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToPersonasCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="16,12"
                            Background="Transparent"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Image Source="avares://ChecadorSSSD/Assets/Icons/people.png" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock Text="Personas"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushBlanco}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToReportesCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="16,12"
                            Background="Transparent"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Image Source="avares://ChecadorSSSD/Assets/Icons/chart.png" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock Text="Reportes"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushBlanco}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToAdministracionCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="16,12"
                            Background="Transparent"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Image Source="avares://ChecadorSSSD/Assets/Icons/settings.png" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock Text="Administracion"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushBlanco}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Abajo: Salir -->
                <Button Grid.Row="2"
                        Command="{Binding ExitCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,12"
                        Background="Transparent"
                        Cursor="Hand"
                        Margin="12,0,12,12">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Image Source="avares://ChecadorSSSD/Assets/Icons/exit.png" Width="22" Height="22" VerticalAlignment="Center"/>
                        <TextBlock Text="Salir"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushRojoError}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Contenido Principal -->
        <Border Grid.Column="1"
                Background="{StaticResource BrushAzulMarino}">
            <ContentControl Content="{Binding SelectedViewModel}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Padding="24">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:ChecadorViewModel">
                        <views:ChecadorView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:PersonasViewModel">
                        <views:PersonasView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:ReportesViewModel">
                        <views:ReportesView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:AdministracionViewModel">
                        <views:AdministracionView />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Border>
    </Grid>
</Window>
